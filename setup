#!/usr/bin/env bash

check_dependency() {
  command -v "$1" >/dev/null 2>&1 || { echo >&2 "Please install $1 before continuing"; exit 1; }
}

echo -e "Checking configuration...\n"
PLATFORM="$(uname -s)"
check_dependency curl
check_dependency git
check_dependency vim
if [ "$PLATFORM" == "Darwin" ]; then
  check_dependency brew
fi

echo -e "Setting up fzf...\n"
if [ "$PLATFORM" == "Darwin" ]; then
  brew install fzf && /usr/local/opt/fzf/install
else
  git clone --depth 1 https://github.com/junegunn/fzf.git ~/.fzf
  ~/.fzf/install
fi

 echo -e "Setting up fish...\n"
 mkdir -p ~/.config/fish/functions
 cp fish/config.fish ~/.config/fish/config.fish
 cp fish/fish_prompt.fish ~/.config/fish/functions/fish_prompt.fish

echo -e "Setting up vim...\n"
mkdir -p ~/.vim/autoload
cp -R vim/. ~/.vim/
cp vimrc ~/.vimrc
vim  +PlugInstall +qall > /dev/null 2>&1
