# vim: syntax=sh

alias ll='ls -Glh'
alias la='ls -AGlh'
alias lt='tree -CFha -L 1'

alias grep='grep --color=auto'

alias y2mp3='youtube-dl --extract-audio --audio-format mp3 --audio-quality 0'

alias myip='dig +short myip.opendns.com @resolver1.opendns.com'

alias path='echo $PATH | tr -s ":" "\n"'

# Git
alias gg='git gui'
alias gti='git'
alias gits='git status'
alias gitb='git branch'
alias gitl='git log'
alias gitc='git checkout'

# Open config files
alias zshrc='vim ~/.zshrc'
alias vimrc='vim ~/.vimrc'

# Brew
alias b='brew'
alias update='brew update && brew upgrade && brew cask upgrade && brew cleanup'

# Make gif from video -> gif imput.mp4 output.gif 
function gif() {
  ffmpeg -i $1 -vf "fps=15,scale=320:-1:flags=lanczos,palettegen" -y palette.png
  ffmpeg -i $1 -i palette.png -filter_complex "fps=15,scale=320:-1:flags=lanczos [x]; [x][1:v] paletteuse" $2
  rm palette.png
}
