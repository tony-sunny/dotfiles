alias ll='ls -Glh'
alias la='ls -AGlh'
alias y2mp3='youtube-dl --extract-audio --audio-format mp3 --audio-quality 0'
alias ip-local='python -c "import socket; print(socket.gethostbyname(socket.gethostname()))"'
alias ip-public='dig +short myip.opendns.com @resolver1.opendns.com'
alias path='echo $PATH | tr -s ":" "\n"'

# Git
alias gti='git'
alias gits='git status'
alias gitb='git branch'
alias gitl='git log'
alias gitg='git gui'

# Apps
command -v subl || alias subl='/Applications/Sublime\ Text.app/Contents/SharedSupport/bin/subl'

# brew
alias update='brew update --verbose && brew upgrade && brew cask upgrade && brew cleanup && brew cask cleanup'
alias install='brew install'
alias search='brew search'
